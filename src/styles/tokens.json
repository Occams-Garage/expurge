{
  "$meta": {
    "name": "expurge design tokens",
    "version": "1.0",
    "note": "Raw palette is theme-independent. Semantic tokens have light + dark values; default to light, switch to dark on prefers-color-scheme:dark or [data-theme=dark]."
  },
  "palette": {
    "cream": "#FBF6EE",
    "oat": "#ECE3D4",
    "pine": "#2C5446",
    "pineHover": "#244839",
    "mint": "#7FB89C",
    "mintHover": "#93C7AC",
    "terracotta": "#B25C3C",
    "terracottaDark": "#C9744E",
    "ink": "#211D18",
    "inkCard": "#2A2620",
    "inkLine": "#3A342C",
    "inkInput": "#2A2620",
    "inkInputBorder": "#433D34"
  },
  "semantic": {
    "light": {
      "bg": "#FBF6EE",
      "surface": "#FBF6EE",
      "fill": "#ECE3D4",
      "border": "#ECE3D4",
      "inputBg": "#FFFFFF",
      "inputBorder": "#DCD2C0",
      "text": "#211D18",
      "textMuted": "#6B6053",
      "textFaint": "#A99B8A",
      "primary": "#2C5446",
      "primaryHover": "#244839",
      "onPrimary": "#FBF6EE",
      "link": "#2C5446",
      "linkHover": "#B25C3C",
      "accent": "#B25C3C",
      "focusRing": "#2C5446",
      "focusRingShadow": "rgba(44,84,70,0.14)",
      "stripBg": "#2C5446",
      "stripKnockout": "#FBF6EE"
    },
    "dark": {
      "bg": "#211D18",
      "surface": "#2A2620",
      "fill": "#2E2A24",
      "border": "#3A342C",
      "inputBg": "#2A2620",
      "inputBorder": "#433D34",
      "text": "#FBF6EE",
      "textMuted": "#C9C2B6",
      "textFaint": "#9C9388",
      "primary": "#7FB89C",
      "primaryHover": "#93C7AC",
      "onPrimary": "#211D18",
      "link": "#7FB89C",
      "linkHover": "#93C7AC",
      "accent": "#C9744E",
      "focusRing": "#7FB89C",
      "focusRingShadow": "rgba(127,184,156,0.2)",
      "stripBg": "#7FB89C",
      "stripKnockout": "#211D18"
    }
  },
  "contrast": {
    "note": "WCAG 2.1 contrast ratios for required pairings.",
    "textSafe": {
      "inkOnCream": { "ratio": 15.6, "level": "AAA" },
      "pineOnCream": { "ratio": 7.9, "level": "AAA" },
      "pineOnOat": { "ratio": 6.7, "level": "AA+" },
      "creamOnInk": { "ratio": 15.6, "level": "AAA" },
      "mintOnInk": { "ratio": 7.4, "level": "AAA" },
      "creamOnPine": { "ratio": 7.9, "level": "AAA" },
      "inkOnMint": { "ratio": 7.4, "level": "AAA" }
    },
    "accentOnly": {
      "terracottaOnCream": { "ratio": 4.3, "level": "AA large/UI only — never body text" },
      "terracottaDarkOnInk": { "ratio": 3.6, "level": "AA large/UI only — never body text" }
    }
  },
  "spacing": { "s1": 4, "s2": 8, "s3": 12, "s4": 16, "s5": 20, "s6": 24, "s7": 32, "s8": 48, "s9": 64, "s10": 96, "unit": "px" },
  "radius": { "strip": 3, "control": 9, "card": 14, "pill": 9999, "unit": "px" },
  "type": {
    "families": {
      "display": "Newsreader",
      "ui": "Hanken Grotesk",
      "mono": "IBM Plex Mono"
    },
    "scale": {
      "display": { "font": "display", "size": [48, 128], "weight": 600, "lineHeight": 1.1, "tracking": "-0.01em" },
      "h1": { "font": "display", "size": [30, 40], "weight": 600, "lineHeight": 1.1, "tracking": "-0.01em" },
      "h2": { "font": "ui", "size": [20, 24], "weight": 600, "lineHeight": 1.25 },
      "body": { "font": "ui", "size": [15, 16], "weight": 400, "lineHeight": 1.6 },
      "small": { "font": "ui", "size": [12.5, 13.5], "weight": 400, "lineHeight": 1.55 },
      "monoLabel": { "font": "mono", "size": [11, 12], "weight": 400, "lineHeight": 1.4, "tracking": "0.14em", "transform": "uppercase" }
    }
  },
  "wordmark": {
    "text": "expurge",
    "font": "Newsreader",
    "weight": 600,
    "case": "lowercase",
    "tracking": "-0.01em",
    "strip": {
      "covers": "pur",
      "fillLight": "#2C5446",
      "fillDark": "#7FB89C",
      "knockoutLight": "#FBF6EE",
      "knockoutDark": "#211D18",
      "perforation": "top + bottom only",
      "cornerRadius": 3,
      "geometryEm": { "left": -0.02, "right": -0.035, "top": 0.24, "bottom": -0.05, "marginLeft": 0.05, "marginRight": 0.065 }
    },
    "minSize": { "wordmark": 24, "glyph": 16, "unit": "px" }
  }
}
